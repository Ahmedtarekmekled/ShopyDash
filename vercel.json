{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "shopydash.store"
        }
      ],
      "destination": "https://www.shopydash.store/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/([^.]*)",
      "destination": "/index.html"
    }
  ]
}
